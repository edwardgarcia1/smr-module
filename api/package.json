	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@casl/ability": "^6.8.0",
		"@elysiajs/bearer": "^1.4.3",
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/jwt": "^1.4.1",
		"@elysiajs/swagger": "^1.3.1",
		"elysia": "^1.4.28",
		"mssql": "^10.0.2"
	}
