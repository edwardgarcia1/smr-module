{
  "name": "api",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --target=bun",
    "start": "NODE_ENV=production bun src/index.ts",
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit",
    "db:migrate": "bun run src/migrate.ts",
    "db:migrate:all": "bun run src/migrate.ts",
    "db:list-tenants": "bun run src/migrate.ts --list"
  },
  "private": true,
  "devDependencies": {
    "@types/big.js": "^6.2.2",
    "@types/bun": "^1.3.12",
    "@types/mssql": "^8.1.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@casl/ability": "^6.8.0",
    "mssql": "^10.0.2",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "big.js": "^7.0.1",
    "elysia": "^1.4.28"
  }
}
